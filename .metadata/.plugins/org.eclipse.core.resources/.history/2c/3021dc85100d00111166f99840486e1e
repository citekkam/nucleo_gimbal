/**
 * Init ICM-20602:
 *  - wake + set clock to PLL (X-gyro)
 *  - set gyro DLPF (CONFIG)
 *  - set sample rate divider
 *  - set gyro full-scale range
 *
 * dlpf_cfg: 0..6  (e.g., 2=94 Hz, 3=44 Hz)
 * smpl_div: output_rate = 1kHz / (1 + smpl_div)   (when DLPF!=0)
 */

void Print2Console(const char* msg1, const char* msg2, int ret)
{
	if (ret == HAL_OK)
	{
		HAL_UART_Transmit(&huart2, (const uint8_t*)msg1, strlen(msg1),100);
	}
	else
	{
		HAL_UART_Transmit(&huart2, (const uint8_t*)msg2, strlen(msg2),100);
	}
	//HAL_Delay(1000);
}

void Calibrate_GYRO()
{
	//int16_t ret_count = 0;
	float gyro_y_cal = 0;
	for (int i = 0; i < 1000; i++) {
		HAL_StatusTypeDef ret = HAL_I2C_Mem_Read(&hi2c1, (ICM20602_ADDRESS<<1) + 1, REG_DATA_GYRO_Y, 1, raw_gyro, 2, 100);
		gyro_y_cal += (int16_t)((raw_gyro[0] << 8) | raw_gyro[1]);
		//if (ret == HAL_OK) {
		//	ret_count++;
		//}
		HAL_Delay(1);
	}
	offset_y = ((float)gyro_y_cal / 1000);

	printf("OFFSET: %.5f\r\n",offset_y);
/*
	*/
}

HAL_StatusTypeDef ICM20602_Init(uint8_t ad0,
                                uint8_t dlpf_cfg,
                                uint8_t smpl_div,
                                icm_gyro_fs_t fs)
{
    HAL_StatusTypeDef st;
    uint8_t v;

    HAL_StatusTypeDef ret = HAL_I2C_IsDeviceReady(&hi2c1, (ICM20602_ADDRESS<<1), 1, 1000);
    Print2Console(DIV_CON, DIV_DISCON, ret);

    uint8_t temp_data = WAKE_AND_PLL;
	ret = HAL_I2C_Mem_Write(&hi2c1, (ICM20602_ADDRESS<<1) + 0, REG_SLEEP_PLL, 1, &temp_data, 1, 100);
	Print2Console(DIV_WAKE, DIV_SLEEP, ret);
	HAL_Delay(500);



	temp_data = BANDWIDTH;
	ret = HAL_I2C_Mem_Write(&hi2c1, (ICM20602_ADDRESS<<1) + 0, REG_DLPF, 1, &temp_data, 1, 100);
	Print2Console(DLPF_SET, DLPF_ERR, ret);

	temp_data = BANDWIDTH_ACC;
	ret = HAL_I2C_Mem_Write(&hi2c1, (ICM20602_ADDRESS<<1) + 0, REG_DLPF_ACC, 1, &temp_data, 1, 100);
	Print2Console(DLPF_SET_ACC, DLPF_ERR_ACC, ret);

	temp_data = FS500;
	ret = HAL_I2C_Mem_Write(&hi2c1, (ICM20602_ADDRESS<<1) + 0, REG_SAMPLE_DIV, 1, &temp_data, 1, 100);
	Print2Console(SR_SET, SR_ERR, ret);

	temp_data = FS_GYRO_2000;
	ret = HAL_I2C_Mem_Write(&hi2c1, (ICM20602_ADDRESS<<1) + 0, REG_CONFIG_GYRO, 1, &temp_data, 1, 100);
	Print2Console(GYRO_CONFIG, GYRO_ERR, ret);

	temp_data = FS_ACC_8G;
	ret = HAL_I2C_Mem_Write(&hi2c1, (ICM20602_ADDRESS<<1) + 0, REG_CONFIG_ACC, 1, &temp_data, 1, 100);
	Print2Console(ACC_CONFIG, ACC_ERR, ret);

	temp_data = FIFO_OFF;
	ret = HAL_I2C_Mem_Write(&hi2c1, (ICM20602_ADDRESS<<1) + 0, FIFO_OFF_REG, 1, &temp_data, 1, 100);

	temp_data = FIFO;
	ret = HAL_I2C_Mem_Write(&hi2c1, (ICM20602_ADDRESS<<1) + 0, FIFO_DENIED_REG, 1, &temp_data, 1, 100);

	Calibrate_GYRO();
	/*
*/
}

void I2C_Bus_Recover(void) {
    GPIO_InitTypeDef GPIO_InitStruct = {0};

    // 1. Konfigurace SCL jako GPIO Output (Open-Drain)
    // Uprav piny podle tvého Nuclea (např. PB6 pro SCL na I2C1)
    GPIO_InitStruct.Pin = GPIO_PIN_6;
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_OD;
    GPIO_InitStruct.Pull = GPIO_PULLUP;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_HIGH;
    HAL_GPIO_Init(GPIOB, &GPIO_InitStruct);

    // Konfigurace SDA jako GPIO Input (abychom viděli, kdy se uvolní)
    GPIO_InitStruct.Pin = GPIO_PIN_7;
    GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
    HAL_GPIO_Init(GPIOB, &GPIO_InitStruct);

    // 2. Poslat 9 pulsů na SCL
    for (int i = 0; i < 9; i++) {
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_RESET);
        HAL_Delay(1); // 500 Hz je víc než dost
        HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_SET);
        HAL_Delay(1);

        // Pokud SDA naskočí do 1, senzor už linku pustil
        if (HAL_GPIO_ReadPin(GPIOB, GPIO_PIN_7) == GPIO_PIN_SET) {
            break;
        }
    }

    // 3. Manuální STOP podmínka
    // SDA jde z 0 na 1, zatímco SCL je 1
    GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_OD;
    GPIO_InitStruct.Pin = GPIO_PIN_7;
    HAL_GPIO_Init(GPIOB, &GPIO_InitStruct);

    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_RESET);
    HAL_Delay(1);
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_6, GPIO_PIN_SET);
    HAL_Delay(1);
    HAL_GPIO_WritePin(GPIOB, GPIO_PIN_7, GPIO_PIN_SET);
    HAL_Delay(1);

    // 4. Vrátit piny zpět do I2C režimu (to udělá HAL_I2C_Init)
}


extern int iic_err;
extern int16_t count_limit;
void Read_Gyro() {
	HAL_StatusTypeDef ret = HAL_I2C_Mem_Read(&hi2c1, (ICM20602_ADDRESS<<1), REG_DATA_GYRO_Y, 1, raw_gyro, 2, 1);
	if (ret != HAL_OK) {
		iic_err += 1;
		HAL_I2C_DeInit(&hi2c1);      // Vypnout I2C
		    I2C_Bus_Recover();           // "Vymlátit" data ze senzoru přes GPIO
		    HAL_I2C_Init(&hi2c1);
	}
	gyro_y_raw = (int16_t)((raw_gyro[0] << 8) | raw_gyro[1]);
	gyro_y_raw -= offset_y;
	gyro_y = ((float)gyro_y_raw/16.4);
	count_limit ++;
	//if (gyro_y > 1990)  {
	//	count_limit++;
	//}

	/*
*/
}

void Read_Data_ACC()
{
	int16_t acc_x_raw, acc_y_raw, acc_z_raw;
 	float acc_x, acc_y, acc_z, rad_XZ;
 	HAL_StatusTypeDef ret = HAL_I2C_Mem_Read(&hi2c1, (ICM20602_ADDRESS<<1), REG_DATA_ACC, 1, data, 6, 1);
	if (ret != HAL_OK) {
		iic_err += 1;
		HAL_I2C_DeInit(&hi2c1);      // Vypnout I2C
		    I2C_Bus_Recover();           // "Vymlátit" data ze senzoru přes GPIO
		    HAL_I2C_Init(&hi2c1);
	}
	acc_x_raw = (int16_t)((data[0] << 8) + data[1]);
	acc_y_raw = (int16_t)((data[2] << 8) + data[3]);
	acc_z_raw = (int16_t)((data[4] << 8) + data[5]);
	acc_x = ((float)acc_x_raw /2048.0);
	acc_y = ((float)acc_y_raw /2048.0);
	acc_z = ((float)acc_z_raw /2048.0);
	rad_XZ  = atan2f(acc_x, acc_z);
	//rad_XZ = atan2f(-acc_x, sqrt(acc_y*acc_y + acc_z*acc_z));
	deg_XZ = (rad_XZ*RAD2DEG);

	/*
*/

}

