bool I2C_IsDeviceReady_LL(I2C_TypeDef *I2Cx,
                          uint8_t devAddr,
                          uint32_t timeout)
{
    uint32_t tick = 0;

    // wait until bus is free
    while (LL_I2C_IsActiveFlag_BUSY(I2Cx))
    {
        if (tick++ > timeout)
            return false;
    }

    // START
    LL_I2C_GenerateStartCondition(I2Cx);
    while (!LL_I2C_IsActiveFlag_SB(I2Cx))
    {
        if (tick++ > timeout)
            return false;
    }

    // send address + WRITE
    LL_I2C_TransmitData8(I2Cx, devAddr << 1);

    while (1)
    {
        // ACK received
        if (LL_I2C_IsActiveFlag_ADDR(I2Cx))
        {
            LL_I2C_ClearFlag_ADDR(I2Cx);
            LL_I2C_GenerateStopCondition(I2Cx);
            return true;
        }

        // NACK received
        if (LL_I2C_IsActiveFlag_AF(I2Cx))
        {
            LL_I2C_ClearFlag_AF(I2Cx);
            LL_I2C_GenerateStopCondition(I2Cx);
            return false;
        }

        if (tick++ > timeout)
        {
            LL_I2C_GenerateStopCondition(I2Cx);
            return false;
        }
    }
}



