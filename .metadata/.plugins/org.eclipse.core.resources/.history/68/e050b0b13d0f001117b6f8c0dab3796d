void onHeartbeat(Heartbeat_msg_t& msg, void* user_data) {

ODriveUserData* odrv_user_data = static_cast<ODriveUserData*>(user_data);

odrv_user_data->last_heartbeat = msg;

odrv_user_data->received_heartbeat = true;

}


