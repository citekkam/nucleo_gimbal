/* USER CODE BEGIN 4 */
void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
    // Zkontrolujeme, zda je to Timer 6 (TIM6)
    if (htim->Instance == TIM6)
    {
        // 1. Cteni IMU (Read_Gyro, Read_Data_ACC)
        Read_Gyro();
        Read_Data_ACC();

        // 2. Aktualizace Komplementarniho Filtru (CF)
        // Predpokladame, ze 'filter' je globalni/extern
        CF_Update(&filter, gyro_y, deg_XZ);

        // 3. Signalizace hlavni smycce, ze je cas na pomale I/O
        cf_ready_for_print_flag = true;

        // 4. Inkrementace citace pro mereni frekvence
        cf_update_count++;
    }
}

